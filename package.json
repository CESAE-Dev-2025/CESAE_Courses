{
  "name": "CESAE_Mobile",
  "version": "0.5.1",
  "description": "A monorepo template built with Bun, Hono, Vite, and React",
  "author": "Steve Simkins",
  "license": "MIT",
  "homepage": "https://github.com/stevedylandev/bhvr",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=client",
    "dev:server": "turbo dev --filter=server",
    "build": "turbo build",
    "build:client": "turbo build --filter=client",
    "build:server": "turbo build --filter=server",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=shared --filter=server"
  },
  "keywords": [
    "pnpm",
    "hono",
    "react",
    "vite",
    "monorepo",
    "turbo"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "turbo": "^2.8.11",
    "workbox-window": "^7.4.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono-rate-limiter": "^0.5.3",
    "mysql2": "^3.17.2",
    "playwright": "^1.58.2",
    "react-router-dom": "^7.13.0"
  }
}
